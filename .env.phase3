# ══════════════════════════════════════════════════════════════════════════════
# PHASE 3.5 - ADVANCED FEATURES CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# FINNHUB API (News + Sentiment)
# ──────────────────────────────────────────────────────────────────────────────
# Free tier: 60 requests/minute
# Get API key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# TELEGRAM ALERTS
# ──────────────────────────────────────────────────────────────────────────────
# Get bot token: Talk to @BotFather on Telegram
# Get chat ID: Talk to @userinfobot on Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=gggg
TELEGRAM_CHAT_ID=ggggg

# ──────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here
RECIPIENT_EMAIL=your_email@gmail.com

# For Gmail: Use App Password (not regular password)
# Create here: https://support.google.com/accounts/answer/185833

# ──────────────────────────────────────────────────────────────────────────────
# REDDIT API (Optional)
# ──────────────────────────────────────────────────────────────────────────────
# Get credentials: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=Meme-Squeeze-Sentinel/2.0
